# ── 美股投资研究平台 — 配置文件 ──────────────────────
# 复制此文件为 .env 并填入你的密钥：
#   cp .env.example .env
#
# 注意：.env 已在 .gitignore 中排除，不会提交到 Git。
#       Render 部署时在 Dashboard → Environment 中设置这些变量。
# ────────────────────────────────────────────────────

# DeepSeek API Key（用于金融课堂和政策新闻的中文翻译）
# 在 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=

# DeepSeek 模型名称（可选，默认 deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat

# DeepSeek API 地址（可选，默认官方地址）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
